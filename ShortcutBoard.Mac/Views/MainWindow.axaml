<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:ShortcutBoard.Mac.Controls"
        x:Class="ShortcutBoard.Mac.Views.MainWindow"
        x:Name="Root"
        Title="ShortcutBoard"
        Width="640" Height="500"
        SystemDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#1E1F22">

    <Border BorderBrush="#3A3D43" BorderThickness="1" CornerRadius="10">
        <Grid Margin="13" RowDefinitions="Auto,Auto,*,Auto">

            <!-- ヘッダー -->
            <Grid Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <Border Background="#3B82F6" CornerRadius="5" Width="23" Height="23">
                        <TextBlock Text="S" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="ShortcutBoard" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1" Content="{Binding ManageButtonLabel}"
                        Command="{Binding ToggleManageCommand}" Padding="11,4" />
            </Grid>

            <!-- 検索・カテゴリ -->
            <Grid Grid.Row="1" Margin="0,0,0,10" ColumnDefinitions="*,10,160">
                <TextBox Grid.Column="0" Watermark="キーワード検索…" FontSize="13"
                         Text="{Binding SearchText, Mode=TwoWay}" />
                <ComboBox Grid.Column="2" HorizontalAlignment="Stretch" FontSize="13"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />
            </Grid>

            <!-- 一覧 -->
            <ListBox Grid.Row="2" Background="Transparent" Padding="0"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedShortcut, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2B2D31" BorderBrush="#3A3D43" BorderThickness="1"
                                CornerRadius="8" Margin="0,0,0,6">
                            <Panel>
                                <!-- 表示モード -->
                                <Grid Margin="11,6" IsVisible="{Binding !IsEditing}"
                                      ColumnDefinitions="165,*,Auto">
                                    <Border Grid.Column="0" Background="#11243B" BorderBrush="#3B82F6"
                                            BorderThickness="1" CornerRadius="5" Padding="8,3"
                                            VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Keys}" Foreground="#8FBEFF"
                                                   FontFamily="Menlo,Consolas,monospace" FontSize="12"
                                                   FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="11,0"
                                               VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Border Background="#34363B" CornerRadius="10" Padding="9,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayCategory}" FontSize="11"
                                                       Foreground="#A8ADB5" />
                                        </Border>
                                        <StackPanel Orientation="Horizontal" Spacing="4"
                                                    IsVisible="{Binding $parent[ListBox].DataContext.IsManageMode}">
                                            <Button Content="↑" Padding="7,2" FontSize="12"
                                                    Command="{Binding $parent[ListBox].DataContext.MoveUpCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="↓" Padding="7,2" FontSize="12"
                                                    Command="{Binding $parent[ListBox].DataContext.MoveDownCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="編集" Padding="9,2" FontSize="11"
                                                    Command="{Binding $parent[ListBox].DataContext.EditItemCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="削除" Padding="9,2" FontSize="11" Foreground="#FF8A8A"
                                                    Command="{Binding $parent[ListBox].DataContext.DeleteItemCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- 編集モード -->
                                <StackPanel Margin="11,10" Spacing="8" IsVisible="{Binding IsEditing}">
                                    <Grid ColumnDefinitions="190,10,*">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock Text="ショートカットキー（直接入力可 / Ctrl・Alt・Cmd＋キーで取得）"
                                                       Foreground="#A8ADB5" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            <ctrl:KeyCaptureTextBox Text="{Binding Keys, Mode=TwoWay}" FontSize="13" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="3">
                                            <TextBlock Text="名前" Foreground="#A8ADB5" FontSize="11" />
                                            <TextBox Text="{Binding Name, Mode=TwoWay}" FontSize="13" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock Text="カテゴリー" Foreground="#A8ADB5" FontSize="11" />
                                            <TextBox Text="{Binding Category, Mode=TwoWay}" Width="180"
                                                     HorizontalAlignment="Left" FontSize="13" />
                                            <ItemsControl ItemsSource="{Binding $parent[ListBox].DataContext.CategorySuggestions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}" Margin="0,4,6,0" Padding="8,2" FontSize="11"
                                                                Command="{Binding $parent[ListBox].DataContext.SetCategoryCommand}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Bottom">
                                            <Button Content="削除" Foreground="#FF8A8A"
                                                    Command="{Binding $parent[ListBox].DataContext.DeleteItemCommand}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="保存"
                                                    Command="{Binding $parent[ListBox].DataContext.SaveItemCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Panel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- フッター -->
            <Grid Grid.Row="3" Margin="0,9,0,0" ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Content="＋ 追加" Padding="11,4"
                        IsVisible="{Binding IsManageMode}"
                        Command="{Binding AddCommand}" />
                <TextBlock Grid.Column="1" Foreground="#A8ADB5" FontSize="11" Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Text="Enter コピー / Esc 閉じる ・ 右上「編集」で追加・並べ替え・削除" />
                <TextBlock Grid.Column="2" Foreground="#A8ADB5" FontSize="11" VerticalAlignment="Center"
                           Text="{Binding Items.Count, StringFormat='{}{0} 件'}" />
            </Grid>
        </Grid>
    </Border>
</Window>
