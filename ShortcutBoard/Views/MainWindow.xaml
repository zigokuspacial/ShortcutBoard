<Window x:Class="ShortcutBoard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:ShortcutBoard.Controls"
        Title="ShortcutBoard"
        Width="620" Height="500"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border x:Name="RootBorder" Background="{StaticResource BgBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="10">
        <Grid Margin="13">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- ヘッダー -->
                <RowDefinition Height="Auto" />   <!-- 検索・カテゴリ -->
                <RowDefinition Height="*" />      <!-- 一覧 -->
                <RowDefinition Height="Auto" />   <!-- フッター -->
            </Grid.RowDefinitions>

            <!-- ヘッダー -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="5"
                            Width="23" Height="23" Margin="0,0,8,0">
                        <TextBlock Text="S" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="ShortcutBoard" FontSize="15" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button Content="{Binding ManageButtonLabel}" Command="{Binding ToggleManageCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Padding="11,4" MinWidth="62" FontSize="12" ToolTip="編集モードの切り替え（並べ替え・編集・削除）" />
            </Grid>

            <!-- 検索・カテゴリ -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" Grid.Column="0" Padding="8,5" FontSize="13"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="0" Text="キーワード検索…" IsHitTestVisible="False"
                           Foreground="{StaticResource SubTextBrush}" Margin="10,0,0,0"
                           VerticalAlignment="Center" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ComboBox x:Name="CategoryCombo" Grid.Column="2" Height="30" FontSize="13"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}" />
            </Grid>

            <!-- 一覧 -->
            <ListBox x:Name="List" Grid.Row="2"
                     Background="Transparent" BorderThickness="0"
                     ItemsSource="{Binding ShortcutsView}"
                     SelectedItem="{Binding SelectedShortcut}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="List_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,0,6" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="8">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- ===== 表示モード（1行・コンパクト） ===== -->
                            <Grid x:Name="DisplayPanel" Margin="11,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="165" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#11243B"
                                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                        CornerRadius="5" Padding="8,3" VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Keys}" Foreground="#8FBEFF"
                                               FontFamily="Consolas, Segoe UI" FontSize="12" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="11,0"
                                           VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{StaticResource SurfaceAltBrush}"
                                            CornerRadius="10" Padding="9,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayCategory}" FontSize="11"
                                                   Foreground="{StaticResource SubTextBrush}" />
                                    </Border>
                                    <!-- 管理モードのときだけ操作ボタンを表示 -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                Visibility="{Binding DataContext.IsManageMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                        <Button Content="↑" Margin="8,0,0,0" Padding="7,2" FontSize="12" ToolTip="1つ上へ"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="↓" Margin="4,0,0,0" Padding="7,2" FontSize="12" ToolTip="1つ下へ"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="編集" Margin="6,0,0,0" Padding="9,2" FontSize="11.5"
                                                Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="削除" Margin="4,0,0,0" Padding="9,2" FontSize="11.5"
                                                Style="{StaticResource DangerButton}"
                                                Click="DeleteRow_Click" Tag="{Binding}" ToolTip="この項目を削除" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- ===== 編集モード ===== -->
                            <StackPanel x:Name="EditPanel" Margin="11,10" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="190" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ショートカットキー（直接入力可 / Ctrl・Alt・Win＋キーで取得）"
                                                   Foreground="{StaticResource SubTextBrush}" FontSize="11.5" Margin="2,0,0,3"
                                                   TextTrimming="CharacterEllipsis" />
                                        <ctrl:KeyCaptureTextBox Style="{StaticResource {x:Type TextBox}}"
                                            Text="{Binding Keys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="名前" Foreground="{StaticResource SubTextBrush}"
                                                   FontSize="11.5" Margin="2,0,0,3" />
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="カテゴリー" Foreground="{StaticResource SubTextBrush}"
                                                   FontSize="11.5" Margin="2,0,0,3" />
                                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                                 HorizontalAlignment="Left" />
                                        <ItemsControl ItemsSource="{Binding DataContext.CategorySuggestions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      Margin="0,6,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}" Margin="0,0,6,6" Padding="8,2" FontSize="11"
                                                            Command="{Binding DataContext.SetCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="削除"
                                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" MinWidth="70" Margin="0,0,8,0" />
                                        <Button Content="保存" Style="{StaticResource AccentButton}"
                                                Command="{Binding DataContext.SaveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" MinWidth="80" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter TargetName="DisplayPanel" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="EditPanel" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 削除トースト（一覧領域の下部に浮かせる・軽い通知） -->
            <Border x:Name="DeleteToast" Grid.Row="2" Visibility="Collapsed"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Background="#333A45" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14,8" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="削除しました" Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" FontSize="12.5" />
                    <Button Content="元に戻す" Click="UndoDelete_Click" Margin="12,0,0,0"
                            Padding="9,3" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- フッター -->
            <Grid Grid.Row="3" Margin="0,9,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Button Content="＋ 追加" Style="{StaticResource AccentButton}"
                            Command="{Binding AddCommand}" Padding="11,4" Margin="0,0,10,0" FontSize="12"
                            Visibility="{Binding IsManageMode, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Foreground="{StaticResource SubTextBrush}" FontSize="11"
                               VerticalAlignment="Center"
                               Text="Enter コピー / Esc 閉じる ・ 右上「編集」で追加・並べ替え・削除" />
                </StackPanel>
                <TextBlock x:Name="CountText" Foreground="{StaticResource SubTextBrush}" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Border>
</Window>
