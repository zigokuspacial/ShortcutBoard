<Window x:Class="ShortcutBoard.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutBoard - 設定"
        Width="480" Height="360"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="設定" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,18" />

        <StackPanel Grid.Row="1">
            <!-- ホットキー -->
            <TextBlock Text="グローバルホットキー" Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,6" />
            <TextBox x:Name="HotkeyBox" IsReadOnly="True" Cursor="Hand"
                     Text="{Binding HotkeyDisplay}"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     ToolTip="ここをクリックして、設定したいキーの組み合わせを押してください" />
            <TextBlock Text="ボックスをクリックし、修飾キー(Ctrl/Alt/Shift/Win)＋キー を押してください。"
                       Foreground="{StaticResource SubTextBrush}" FontSize="11.5" Margin="2,6,0,0"
                       TextWrapping="Wrap" />

            <!-- 自動起動 -->
            <CheckBox Content="Windows 起動時に自動起動する"
                      IsChecked="{Binding RunAtStartup}" Margin="0,22,0,0" />
            <TextBlock Text="サインイン時に ShortcutBoard をバックグラウンドで起動します（管理者権限不要）。"
                       Foreground="{StaticResource SubTextBrush}" FontSize="11.5" Margin="26,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Click="Cancel_Click" Margin="0,0,8,0" MinWidth="90" />
            <Button Content="OK" Style="{StaticResource AccentButton}" Click="Ok_Click" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
