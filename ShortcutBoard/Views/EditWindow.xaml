<Window x:Class="ShortcutBoard.Views.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutBoard - 編集"
        Width="760" Height="540"
        MinWidth="640" MinHeight="440"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左: 一覧 -->
            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <ListBox x:Name="ItemList" Background="Transparent" BorderThickness="0" Margin="4"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedItem}"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="2" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="10,8">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Keys}" Foreground="{StaticResource SubTextBrush}"
                                           FontSize="11.5" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- 右: 詳細フォーム -->
            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                <Grid Margin="18" IsEnabled="{Binding HasSelection}">
                    <StackPanel>
                        <TextBlock Text="ショートカットキー" Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding SelectedItem.Keys, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="名前" Foreground="{StaticResource SubTextBrush}" Margin="0,14,0,4" />
                        <TextBox Text="{Binding SelectedItem.Name, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="説明" Foreground="{StaticResource SubTextBrush}" Margin="0,14,0,4" />
                        <TextBox Text="{Binding SelectedItem.Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="80"
                                 VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" />

                        <TextBlock Text="カテゴリー" Foreground="{StaticResource SubTextBrush}" Margin="0,14,0,4" />
                        <TextBox Text="{Binding SelectedItem.Category, UpdateSourceTrigger=PropertyChanged}" />

                        <ItemsControl ItemsSource="{Binding CategorySuggestions}" Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" Margin="0,0,6,6" Padding="9,3" FontSize="11.5"
                                            Click="CategorySuggestion_Click" Tag="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 下部: 操作ボタン -->
        <Grid Grid.Row="1" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="＋ 追加" Command="{Binding AddCommand}" Margin="0,0,8,0" />
                <Button Content="🗑 削除" Command="{Binding DeleteCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="DirtyMark" Text="● 未保存" Foreground="#E0A33B"
                           VerticalAlignment="Center" Margin="0,0,12,0" FontSize="12"
                           Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                <Button Content="閉じる" Click="Close_Click" Margin="0,0,8,0" MinWidth="80" />
                <Button Content="保存" Style="{StaticResource AccentButton}" Click="Save_Click" MinWidth="90" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
